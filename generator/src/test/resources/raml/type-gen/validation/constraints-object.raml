#%RAML 1.0
title: Test API
uses:
  sunday: https://outfoxx.github.io/sunday-generator/sunday.raml
mediaType:
- application/json

types:

  Test:
    type: object
    minProperties: 1
    maxProperties: 3
    properties:
      value: string

/tests/{id}:

  get:
    displayName: fetchTest
    responses:
      200:
        body:
          type: Test
