#%RAML 1.0
title: Sunday Behavior API
uses:
  sunday: https://outfoxx.github.io/sunday-generator/sunday.raml
mediaType:
- application/json

(sunday.problemTypes):
  invalid_id:
    status: 400
    title: Invalid Id
    detail: The id contains one or more invalid characters.
    custom:
      offending_id: string
  unavailable:
    status: 503
    title: Unavailable
    detail: The service is temporarily unavailable.
    custom:
      retry_after: integer

types:
  Project:
    type: object
    properties:
      id: string
      name: string
  ProjectCreated:
    type: object
    properties:
      id: string
      name: string
  ProjectDeleted:
    type: object
    properties:
      id: string

/projects/{projectId}:
  uriParameters:
    projectId: string
  get:
    displayName: fetchProject
    (sunday.problems): [invalid_id, unavailable]
    (sunday.nullify): [invalid_id, 404]
    responses:
      200:
        body:
          application/json:
            type: Project
  /request:
    post:
      displayName: createProjectRequest
      (sunday.requestOnly): true
      body:
        application/json:
          type: Project
      responses:
        202:
  /response:
    get:
      displayName: fetchProjectResponse
      (sunday.responseOnly): true
      responses:
        200:
          body:
            application/json:
              type: Project
  /events:
    /source:
      get:
        displayName: fetchProjectEvents
        (sunday.eventSource): true
        responses:
          200:
            body:
              text/event-stream:
                type: ProjectCreated | ProjectDeleted
    /stream:
      get:
        displayName: streamProjectEvents
        (sunday.eventStream): discriminated
        responses:
          200:
            body:
              application/json:
                type: ProjectCreated | ProjectDeleted
