#%RAML 1.0
title: Problem URI Parity API
uses:
  sunday: https://outfoxx.github.io/sunday-generator/sunday.raml
  problems: problem-uri-library.raml
baseUri: https://api.example.com/v1/
mediaType:
- application/json

(sunday.problemBaseUri): "{scheme}://errors.example.com/{version}/"
(sunday.problemUriParams): { scheme: "https", version: "v2" }
(sunday.problemTypes):
  project_not_found:
    status: 404
    title: Project Not Found
    detail: The requested project does not exist.

types:
  Project:
    type: object
    properties:
      id: string

/projects/{projectId}:
  uriParameters:
    projectId: string
  get:
    displayName: fetchProject
    (sunday.problems): [invalid_id, project_not_found]
    responses:
      200:
        body:
          application/json:
            type: Project
