#%RAML 1.0
title: Problem Payloads API
uses:
  sunday: https://outfoxx.github.io/sunday-generator/sunday.raml
mediaType:
- application/json

(sunday.problemTypes):
  invalid_id:
    status: 400
    title: Invalid Id
    detail: The id contains one or more invalid characters.
    custom:
      offending_id: string

types:
  Project:
    type: object
    properties:
      id: string

/projects/{projectId}:
  uriParameters:
    projectId: string
  get:
    displayName: fetchProject
    (sunday.problems): [invalid_id]
    responses:
      200:
        body:
          application/json:
            type: Project
