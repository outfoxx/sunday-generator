#%RAML 1.0
title: External Discriminator Missing Property Regression
uses:
  sunday: https://outfoxx.github.io/sunday-generator/sunday.raml
mediaType:
- application/json

types:
  Parent:
    type: object
    discriminator: kind
    properties:
      value: string

  Child:
    type: Parent
    properties:
      other: string

/tests:
  get:
    responses:
      200:
        body:
          type: Child
